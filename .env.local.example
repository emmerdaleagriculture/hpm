# ==============================================================================
# .env.local.example
# ==============================================================================
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — it never leaves your machine.
#
# Keys marked (SECRET) must never be pasted anywhere public.
# Keys marked (SAFE) are fine to share — they're public identifiers.
# ==============================================================================

# ------------------------------------------------------------------------------
# Payload secret — used to sign JWT tokens for admin sessions.
# (SECRET) Generate a random 64+ character string. Easy way:
#   openssl rand -base64 48
# Or use https://www.random.org/strings to generate one.
# ------------------------------------------------------------------------------
PAYLOAD_SECRET=

# ------------------------------------------------------------------------------
# Site URL — where your site is hosted. For local dev, leave as-is.
# In production, Vercel will set this automatically.
# (SAFE)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Supabase Postgres — the Transaction pooler connection string.
# (SECRET — contains your database password)
#
# Format:
#   postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres
#
# Your project ref: unakyuksioglmihvipmi
# Your region:      eu-central-1
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.unakyuksioglmihvipmi:YOUR-DB-PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# ------------------------------------------------------------------------------
# Supabase S3 (for media storage)
# (SECRET for ACCESS_KEY_ID and SECRET_ACCESS_KEY, SAFE for the rest)
# ------------------------------------------------------------------------------
SUPABASE_S3_ENDPOINT=https://unakyuksioglmihvipmi.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=eu-central-1
SUPABASE_S3_BUCKET=hpm-media
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=

# ------------------------------------------------------------------------------
# Resend (for contact form emails — optional, can be added later)
# (SECRET)
# Sign up at https://resend.com — free tier covers 3,000 emails/month.
# ------------------------------------------------------------------------------
RESEND_API_KEY=
CONTACT_FORM_TO=tom@hampshirepaddockmanagement.com
CONTACT_FORM_FROM=noreply@hampshirepaddockmanagement.com

# ------------------------------------------------------------------------------
# Google Search Console (for the /admin-stats dashboard — optional)
# (SECRET for CLIENT_SECRET, SAFE for the rest)
#
# Uses OAuth (not a service account — GCP org policy blocks SA keys
# on new projects by default).
#
# 1. GCP Console → APIs & Services → Library → enable "Search Console API"
# 2. APIs & Services → Credentials → Create Credentials → OAuth client ID
#       Application type: Web application
#       Authorized redirect URIs:
#         http://localhost:3000/admin-stats/auth/callback   (dev)
#         https://hampshirepaddockmanagement.com/admin-stats/auth/callback (prod)
# 3. Set the two values below.
# 4. Visit /admin-stats and click "Connect to Google" — uses the
#    Google account already verified on the GSC property, so no
#    extra "Add user" step in Search Console.
# 5. SITE_URL is either a domain property ("sc-domain:example.com") or
#    a URL-prefix property ("https://example.com/").
# ------------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GSC_SITE_URL=sc-domain:hampshirepaddockmanagement.com
